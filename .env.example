# Public application URL used to create share links.
APP_URL=http://localhost:3000

# Neon pooled PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/screenly?sslmode=require

# Temporary shared credential for the recorder API. Use at least 32 random
# characters. Per-user tokens replace this during the authentication phase.
UPLOAD_API_TOKEN=replace-with-a-long-random-token-at-least-32-characters

# Lightweight browser authentication for the single internal workspace.
WORKSPACE_PASSWORD=replace-with-your-team-workspace-password
SESSION_SECRET=replace-with-at-least-32-random-characters

# Any S3-compatible object store: Cloudflare R2, DigitalOcean Spaces, AWS S3,
# or MinIO. Omit S3_ENDPOINT when using AWS S3.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=screenly
S3_ACCESS_KEY_ID=screenly
S3_SECRET_ACCESS_KEY=replace-with-a-long-storage-secret
S3_FORCE_PATH_STYLE=true

# Optional CDN/public bucket base URL. When omitted, playback uses signed URLs.
# S3_PUBLIC_BASE_URL=https://media.example.com
