# Public application URL used to create share links.
APP_URL=http://localhost:3000

# PostgreSQL credentials and database. In Cloud Run, CLOUD_SQL_INSTANCE replaces
# the URL host with the Cloud SQL Unix socket mounted at /cloudsql.
DATABASE_URL=postgresql://screenly:replace-with-a-url-encoded-password@localhost:5432/screenly
# CLOUD_SQL_INSTANCE=your-google-cloud-project:us-central1:screenly
DATABASE_MAX_CONNECTIONS=5

# Optional recovery credential for recorder uploads to the fixed default
# workspace only. Use at least 32 random characters.
UPLOAD_API_TOKEN=replace-with-a-long-random-token-at-least-32-characters

# HMAC signing key for 30-day browser sessions.
SESSION_SECRET=replace-with-at-least-32-random-characters

# Initial owner bootstrap (run `pnpm user:bootstrap` after migrations).
OWNER_USERNAME=admin
OWNER_EMAIL=admin@example.com
OWNER_PASSWORD=replace-with-at-least-12-characters
WORKSPACE_NAME=Screenly

# Optional invitation delivery. Without both values, invitations are created
# with a copyable URL and marked failed rather than reported as sent.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Screenly <screenly@example.com>

# Processing dispatch. Keep "manual" locally, or use "cloud-run-job" in Google
# Cloud and grant the web service account permission to run the named job.
PROCESSOR_MODE=manual
GCP_PROJECT_ID=your-google-cloud-project
GCP_REGION=us-central1
GCP_PROCESSOR_JOB=screenly-processor
HLS_THRESHOLD_SECONDS=1200

# Optional Slack inline playback. Install the Slack app manifest for APP_URL's
# hostname, then provide the installed bot token to both web and worker. The
# signing secret is used only by the web Events API endpoint.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# Published macOS build shown on /download.
MAC_APP_VERSION=0.1.0
MAC_APP_DOWNLOAD_URL=https://media.example.com/releases/Screenly-latest.dmg
# MAC_APP_SHA256=

# Local MinIO defaults.
STORAGE_BACKEND=s3
STORAGE_BUCKET=screenly
STORAGE_ACCESS_KEY_ID=screenly
STORAGE_SECRET_ACCESS_KEY=screenly-local-development-secret
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# In production, set STORAGE_BACKEND=gcs and replace the access ID and secret
# with a Cloud Storage HMAC key. The GCS endpoint and signing region are selected
# automatically; STORAGE_ENDPOINT and STORAGE_FORCE_PATH_STYLE are ignored.

# Optional CDN/public bucket base URL. When omitted, playback uses signed URLs.
# STORAGE_PUBLIC_BASE_URL=https://media.example.com
